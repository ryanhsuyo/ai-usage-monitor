{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "AI Usage Monitor",
  "version": "0.1.0",
  "identifier": "com.aiusagemonitor.app",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1422",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "AI Usage Monitor",
        "width": 1180,
        "height": 820,
        "minWidth": 900,
        "minHeight": 640,
        "resizable": true,
        "fullscreen": false,
        "visible": true
      }
    ],
    "security": {
      "csp": null
    },
    "trayIcon": {
      "id": "main-tray",
      "iconPath": "icons/icon.png",
      "iconAsTemplate": true,
      "tooltip": "AI Usage Monitor",
      "menuOnLeftClick": false
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "Productivity",
    "shortDescription": "Local-first AI usage monitor",
    "longDescription": "Monitor AI subscription usage, forecast exhaustion, predict resets, and get notified across desktop, Discord, Slack, Telegram and custom webhooks. All data stays on your machine."
  },
  "plugins": {}
}
